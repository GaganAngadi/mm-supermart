generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum ShopStatus {
  ACTIVE
  SUSPENDED
}

enum OrderStatus {
  DRAFT
  HELD
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  CREDIT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AttendanceSource {
  MANUAL
  BIOMETRIC
  QR
  API
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PENDING
  PAID
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  RECEIVABLE
  PAYABLE
  TAX
  CASH
  BANK
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  CONVERTED
  EXPIRED
}

enum SyncDirection {
  IMPORT
  EXPORT
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Json
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Shop {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  ownerName   String
  email       String     @unique
  phone       String
  gstin       String?
  address     String?
  status      ShopStatus @default(ACTIVE)
  users       User[]
  branches    Branch[]
  categories  Category[]
  suppliers   Supplier[]
  customers   Customer[]
  products    Product[]
  settings    Setting[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  shopId       String?
  shop         Shop?      @relation(fields: [shopId], references: [id])
  employee     Employee?
  loginActivity LoginActivity[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([roleId])
  @@index([shopId])
  @@index([status])
}

model Branch {
  id          String      @id @default(cuid())
  shopId      String?
  shop        Shop?       @relation(fields: [shopId], references: [id])
  name        String
  code        String
  address     String
  phone       String?
  gstin       String?
  inventories Inventory[]
  employees   Employee[]
  orders      Order[]
  estimates   Estimate[]
  attendance  Attendance[]
  purchases   Purchase[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([shopId, code])
  @@index([shopId])
}

model Category {
  id        String    @id @default(cuid())
  shopId    String?
  shop      Shop?     @relation(fields: [shopId], references: [id])
  name      String
  parentId  String?
  parent    Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([shopId])
  @@index([parentId])
}

model Supplier {
  id             String          @id @default(cuid())
  shopId         String?
  shop           Shop?           @relation(fields: [shopId], references: [id])
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  gstin          String?
  pendingPayment Decimal         @default(0)
  products       Product[]
  purchaseOrders PurchaseOrder[]
  purchases      Purchase[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([shopId])
}

model Product {
  id                String       @id @default(cuid())
  shopId            String?
  shop              Shop?        @relation(fields: [shopId], references: [id])
  name              String
  sku               String
  barcode           String?      @db.VarChar(50)
  barcodeType       String?      @map("barcode_type") @db.VarChar(20)
  qrCode            String?      @map("qr_code") @db.Text
  lastPrintedAt     DateTime?    @map("last_printed_at")
  brand             String?
  description       String?
  imageUrl          String?
  unit              String       @default("pcs")
  mrp               Decimal
  sellingPrice      Decimal
  costPrice         Decimal      @default(0)
  gstRate           Decimal      @default(0)
  taxCode           String?
  lowStockThreshold Int          @default(10)
  categoryId        String
  category          Category     @relation(fields: [categoryId], references: [id])
  supplierId        String?
  supplier          Supplier?    @relation(fields: [supplierId], references: [id])
  batches           ProductBatch[]
  inventories       Inventory[]
  orderItems        OrderItem[]
  purchaseItems     PurchaseItem[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([name])
  @@index([shopId])
  @@unique([shopId, sku])
  @@unique([shopId, barcode])
  @@index([categoryId])
  @@index([supplierId])
}

model ProductBatch {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  batchNo     String
  mfgDate     DateTime?
  expiryDate  DateTime?
  quantity    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Inventory {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  quantity  Int      @default(0)
  reserved  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId])
  @@index([branchId])
}

model InventoryItem {
  id              String   @id @default(cuid())
  itemCode        String   @unique @map("item_code") @db.VarChar(50)
  barcodeNumber   String   @unique @map("barcode_number") @db.VarChar(50)
  barcodeType     String   @default("Code128") @map("barcode_type") @db.VarChar(20)
  itemName        String   @map("item_name")
  itemNameKn      String?  @map("item_name_kn")
  mainCategory    String?  @map("main_category")
  subCategory     String?  @map("sub_category")
  companyName     String?  @map("company_name")
  packing         String?
  size            String?
  unit            String?
  hsnCode         String?  @map("hsn_code")
  openingStock    Decimal  @default(0) @map("opening_stock")
  currentStock    Decimal  @default(0) @map("current_stock")
  purchasePrice   Decimal  @default(0) @map("purchase_price")
  costPrice       Decimal  @default(0) @map("cost_price")
  sellingPrice    Decimal  @default(0) @map("selling_price")
  dealerPrice     Decimal  @default(0) @map("dealer_price")
  mrp             Decimal  @default(0)
  discountPercent Decimal  @default(0) @map("discount_percent")
  gstPercent      Decimal  @default(0) @map("gst_percent")
  rackLocation    String?  @map("rack_location")
  minimumStock    Decimal  @default(0) @map("minimum_stock")
  reorderQuantity Decimal  @default(0) @map("reorder_quantity")
  salesAccount    String?  @map("sales_account")
  purchaseAccount String?  @map("purchase_account")
  labelWidth      Decimal  @default(50) @map("label_width")
  labelHeight     Decimal  @default(25) @map("label_height")
  printCount      Int      @default(0) @map("print_count")
  lastPrinted     DateTime? @map("last_printed")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("inventory_items")
  @@index([itemName])
  @@index([mainCategory])
  @@index([companyName])
}

model Customer {
  id            String   @id @default(cuid())
  shopId        String?
  shop          Shop?    @relation(fields: [shopId], references: [id])
  name          String
  mobile        String
  email         String?
  address       String?
  loyaltyPoints Int      @default(0)
  creditLimit   Decimal  @default(0)
  creditBalance Decimal  @default(0)
  orders        Order[]
  estimates     Estimate[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
  @@index([shopId])
  @@index([mobile])
  @@unique([shopId, mobile])
}

model Order {
  id         String      @id @default(cuid())
  invoiceNo  String      @unique
  branchId   String
  branch     Branch      @relation(fields: [branchId], references: [id])
  customerId String?
  customer   Customer?   @relation(fields: [customerId], references: [id])
  subtotal   Decimal
  discount   Decimal     @default(0)
  tax        Decimal     @default(0)
  total      Decimal
  status     OrderStatus @default(DRAFT)
  notes      String?
  items      OrderItem[]
  payments   Payment[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([branchId, createdAt])
  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Decimal
  unitPrice Decimal
  gstRate   Decimal @default(0)
  total     Decimal?
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id])
  method    PaymentMethod
  amount    Decimal
  status    PaymentStatus @default(PENDING)
  reference String?
  createdAt DateTime      @default(now())

  @@index([method])
  @@index([status])
}

model LedgerEntry {
  id          String      @id @default(cuid())
  date        DateTime    @default(now())
  accountName String
  accountType AccountType
  description String?
  debit       Decimal     @default(0)
  credit      Decimal     @default(0)
  reference   String?
  createdAt   DateTime    @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  category    String
  vendor      String?
  amount      Decimal
  gstRate     Decimal  @default(0)
  paymentMode String
  notes       String?
  createdAt   DateTime @default(now())
}

model BankAccount {
  id            String   @id @default(cuid())
  name          String   @unique
  type          AccountType @default(BANK)
  accountNumber String?
  ifsc          String?
  openingBalance Decimal @default(0)
  currentBalance Decimal @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Estimate {
  id         String         @id @default(cuid())
  estimateNo String         @unique
  branchId   String
  branch     Branch         @relation(fields: [branchId], references: [id])
  customerId String?
  customer   Customer?      @relation(fields: [customerId], references: [id])
  status     EstimateStatus @default(DRAFT)
  validUntil DateTime?
  notes      String?
  subtotal   Decimal
  discount   Decimal        @default(0)
  tax        Decimal        @default(0)
  total      Decimal
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Department {
  id           String        @id @default(cuid())
  name         String        @unique
  description  String?
  employees    Employee[]
  designations Designation[]
}

model Designation {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
}

model Shift {
  id        String     @id @default(cuid())
  name      String
  startTime String
  endTime   String
  employees Employee[]
}

model Employee {
  id               String             @id @default(cuid())
  employeeCode     String             @unique
  fullName         String
  profilePhotoUrl  String?
  mobile           String
  email            String             @unique
  address          String?
  aadhaar          String?
  pan              String?
  dateOfJoining    DateTime
  salary           Decimal
  bankName         String?
  bankAccountNo    String?
  ifsc             String?
  emergencyContact String?
  status           EmployeeStatus     @default(ACTIVE)
  userId           String?            @unique
  user             User?              @relation(fields: [userId], references: [id])
  branchId         String
  branch           Branch             @relation(fields: [branchId], references: [id])
  departmentId     String
  department       Department         @relation(fields: [departmentId], references: [id])
  designationId    String
  designation      Designation        @relation(fields: [designationId], references: [id])
  shiftId          String?
  shift            Shift?             @relation(fields: [shiftId], references: [id])
  attendance       Attendance[]
  leaves           Leave[]
  payrolls         Payroll[]
  tasks            EmployeeTask[]     @relation("TaskAssignee")
  assignedTasks    EmployeeTask[]     @relation("TaskAssigner")
  performance      EmployeePerformance[]
  documents        EmployeeDocument[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Attendance {
  id          String           @id @default(cuid())
  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id])
  branchId    String
  branch      Branch           @relation(fields: [branchId], references: [id])
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  source      AttendanceSource @default(MANUAL)
  lateMinutes Int              @default(0)
  overtimeMin Int              @default(0)
  notes       String?

  @@index([employeeId, date])
  @@index([branchId, date])
}

model Leave {
  id         String      @id @default(cuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id])
  type       String
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     LeaveStatus @default(PENDING)
  approvedBy String?
  createdAt  DateTime    @default(now())
}

model Payroll {
  id          String        @id @default(cuid())
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id])
  month       Int
  year        Int
  baseSalary  Decimal
  overtimePay Decimal       @default(0)
  bonus       Decimal       @default(0)
  deductions  Decimal       @default(0)
  netSalary   Decimal
  payslipUrl  String?
  status      PayrollStatus @default(DRAFT)
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
}

model EmployeeTask {
  id          String     @id @default(cuid())
  title       String
  description String?
  assigneeId  String
  assignee    Employee   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assignerId  String?
  assigner    Employee?  @relation("TaskAssigner", fields: [assignerId], references: [id])
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  comments    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model EmployeePerformance {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  reviewPeriod    String
  rating          Decimal
  kpis            Json
  taskCompletion  Decimal  @default(0)
  productivity    Decimal  @default(0)
  managerComments String?
  createdAt       DateTime @default(now())
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String
  fileUrl    String
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model PurchaseOrder {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  poNumber   String   @unique
  status     String   @default("PENDING")
  total      Decimal  @default(0)
  createdAt  DateTime @default(now())
}

model Purchase {
  id            String         @id @default(cuid())
  purchaseNo    String         @unique
  supplierId    String
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  branchId      String
  branch        Branch         @relation(fields: [branchId], references: [id])
  invoiceUrl    String?
  subtotal      Decimal        @default(0)
  tax           Decimal        @default(0)
  total         Decimal        @default(0)
  paidAmount    Decimal        @default(0)
  status        String         @default("PENDING")
  items         PurchaseItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([supplierId])
  @@index([branchId, createdAt])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Decimal
  unitCost   Decimal
  gstRate    Decimal  @default(0)
  total      Decimal  @default(0)

  @@index([productId])
}

model LoginActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model GoogleSheetSync {
  id            String        @id @default(cuid())
  sheetUrl      String
  sheetId       String?
  range         String?
  module        String
  direction     SyncDirection
  status        SyncStatus    @default(PENDING)
  rowsProcessed Int           @default(0)
  error         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([module, status])
}

model Report {
  id        String   @id @default(cuid())
  name      String
  type      String
  filters   Json?
  fileUrl   String?
  createdAt DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id])
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, key])
  @@index([shopId])
}
