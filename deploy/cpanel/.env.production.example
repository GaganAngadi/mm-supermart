NODE_ENV=production
PORT=4000

# cPanel PostgreSQL database created from cPanel > PostgreSQL Databases.
DATABASE_URL=postgresql://cpanel_db_user:strong_database_password@127.0.0.1:5432/cpanel_database_name?schema=public

# Allow only your hosted web origin and local desktop app sync origin.
WEB_ORIGIN=https://pos.mmsupermart.in

# Use long random values. Keep JWT and sync secrets different.
JWT_SECRET=change-this-to-a-64-character-random-secret
JWT_REFRESH_SECRET=change-this-to-a-different-64-character-random-secret
SYNC_SHARED_SECRET=change-this-to-the-same-token-used-inside-the-electron-pos
CLOUD_SYNC_TOKEN=change-this-to-the-same-token-used-inside-the-electron-pos

# cPanel Redis service.
REDIS_URL=redis://127.0.0.1:6379

# Optional barcode product lookup keys.
UPCITEMDB_API_KEY=
BARCODELOOKUP_API_KEY=

# Google Drive backup. Store the JSON as one compact line.
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_BACKUP_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Cloud backup output path inside your cPanel home folder.
CLOUD_BACKUP_DIR=./backups/postgres
CLOUD_BACKUP_RETENTION_DAYS=90
