{
  "name": "mm-supermart-erp",
  "version": "1.0.0",
  "description": "M&M SuperMart web retail billing and inventory software",
  "author": "M&M SuperMart",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "node node_modules/npm-run-all/bin/npm-run-all/index.js --parallel dev:web dev:api",
    "dev:webapi": "node node_modules/npm-run-all/bin/npm-run-all/index.js --parallel dev:web dev:api",
    "dev:web": "npm --workspace client run dev",
    "dev:api": "npm --workspace server run dev",
    "build": "npm --workspaces run build",
    "lint": "npm --workspaces run lint",
    "typecheck": "npm --workspaces run typecheck",
    "install:local": "powershell -ExecutionPolicy Bypass -File scripts/install-local.ps1",
    "start:local": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1",
    "db:generate": "npm --workspace server run prisma:generate",
    "db:migrate": "npm --workspace server run prisma:migrate",
    "db:seed": "npm --workspace server run prisma:seed",
    "db:backup:daily": "node scripts/backup-database.mjs daily",
    "db:backup:weekly": "node scripts/backup-database.mjs weekly",
    "db:backup:monthly": "node scripts/backup-database.mjs monthly"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/sql.js": "^1.4.11",
    "adm-zip": "^0.5.17",
    "sql.js": "^1.14.1"
  }
}
