{
  "name": "mm-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-bin.cjs tsx/dist/cli.mjs watch src/server.ts",
    "build": "node scripts/run-bin.cjs typescript/bin/tsc",
    "start": "node dist/server.js",
    "lint": "node scripts/run-bin.cjs eslint/bin/eslint.js src --ext .ts",
    "typecheck": "node scripts/run-bin.cjs typescript/bin/tsc --noEmit",
    "postinstall": "node scripts/run-bin.cjs prisma/build/index.js generate --schema ./prisma/schema.prisma",
    "prisma:generate": "node scripts/run-bin.cjs prisma/build/index.js generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "node scripts/run-bin.cjs prisma/build/index.js migrate dev --schema ./prisma/schema.prisma --name init",
    "prisma:deploy": "node scripts/run-bin.cjs prisma/build/index.js migrate deploy --schema ./prisma/schema.prisma",
    "prisma:seed": "node scripts/run-bin.cjs tsx/dist/cli.mjs ./prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "googleapis": "^144.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "redis": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  }
}

